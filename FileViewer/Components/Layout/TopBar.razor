<header class="top-bar">
    <div class="top-bar-left">
        <button class="icon-btn" title="Toggle sidebar" @onclick="OnToggleSidebar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
        </button>
        <h1 class="app-title">File Viewer</h1>
    </div>
    <div class="top-bar-right">
        <span id="current-file-path" class="file-path-display">@CurrentFilePath</span>

        @if (ShowSaveButton)
        {
            <button id="save-btn" class="btn btn-save" title="Save changes to disk" @onclick="OnSave">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
                    <polyline points="17,21 17,13 7,13 7,21"/>
                    <polyline points="7,3 7,8 15,8"/>
                </svg>
                Save
            </button>
        }

        <button id="grant-access-btn"
                class="btn btn-access"
                title="@(HasFolderAccess ? "Folder access granted" : "Grant folder access for saving files")"
                @onclick="OnGrantAccess">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/>
            </svg>
            @(HasFolderAccess ? "Access Granted" : "Grant Folder Access")
        </button>

        <button id="theme-toggle" class="theme-toggle" title="Toggle light/dark theme" @onclick="OnToggleTheme">
            @if (Theme == "dark")
            {
                <!-- Sun icon for dark mode (click to switch to light) -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
            }
            else
            {
                <!-- Moon icon for light mode (click to switch to dark) -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
                </svg>
            }
        </button>
    </div>
</header>

@code {
    [Parameter] public string? CurrentFilePath { get; set; }
    [Parameter] public string? CurrentFileType { get; set; }
    [Parameter] public bool IsDirty { get; set; }
    [Parameter] public bool HasFolderAccess { get; set; }
    [Parameter] public bool IsFileSystemSupported { get; set; }
    [Parameter] public string Theme { get; set; } = "light";
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnGrantAccess { get; set; }
    [Parameter] public EventCallback OnToggleTheme { get; set; }

    private bool ShowSaveButton =>
        CurrentFileType == "markdown" ||
        (CurrentFileType == "excel" && CurrentFilePath != null &&
         CurrentFilePath.EndsWith(".csv", StringComparison.OrdinalIgnoreCase));
}
