<aside id="sidebar" class="sidebar@(IsCollapsed ? " collapsed" : "")">
    <div class="sidebar-header">
        <span class="sidebar-title">Explorer</span>
        <div class="sidebar-actions">
            @if (IsOpenFolderMode)
            {
                <button id="reset-folder-btn" class="btn btn-open-folder" title="Reset to default data/ folder" @onclick="OnResetFolder">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="1,4 1,10 7,10"/>
                        <path d="M3.51 15a9 9 0 105.64-11.36L1 10"/>
                    </svg>
                    Reset
                </button>
            }
            <button id="open-folder-btn" class="btn btn-open-folder" title="Open a folder from your filesystem" @onclick="OnOpenFolder">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/>
                    <line x1="12" y1="11" x2="12" y2="17"/>
                    <line x1="9" y1="14" x2="15" y2="14"/>
                </svg>
                Open Folder
            </button>
        </div>
    </div>
    <nav id="nav-tree" class="nav-tree">
        @if (!IsOpenFolderMode)
        {
            <NavTree Nodes="@FileTreeNodes"
                     SelectedFilePath="@SelectedFilePath"
                     OnFileSelected="OnFileSelected" />
        }
        @* In open-folder mode, JS renders the tree directly into #nav-tree *@
    </nav>
</aside>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public bool IsOpenFolderMode { get; set; }
    [Parameter] public List<FileNode> FileTreeNodes { get; set; } = new();
    [Parameter] public string? SelectedFilePath { get; set; }
    [Parameter] public EventCallback OnOpenFolder { get; set; }
    [Parameter] public EventCallback OnResetFolder { get; set; }
    [Parameter] public EventCallback<FileNode> OnFileSelected { get; set; }
}
