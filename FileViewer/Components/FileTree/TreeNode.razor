@if (Node.Type == "folder")
{
    <div class="tree-item tree-folder tree-indent-@Indent" @onclick="ToggleExpanded" @onclick:stopPropagation="true">
        <span class="tree-chevron@(_isExpanded ? " expanded" : "")">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9,18 15,12 9,6"/>
            </svg>
        </span>
        @if (_isExpanded)
        {
            <span class="tree-icon folder-icon open">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/>
                </svg>
            </span>
        }
        else
        {
            <span class="tree-icon folder-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/>
                </svg>
            </span>
        }
        <span class="tree-name">@Node.Name</span>
    </div>

    @if (_isExpanded && Node.Children != null)
    {
        @foreach (var child in Node.Children)
        {
            <TreeNode Node="@child"
                      Indent="@(Indent + 1)"
                      SelectedFilePath="@SelectedFilePath"
                      OnFileSelected="OnFileSelected" />
        }
    }
}
else
{
    <div class="tree-item tree-file tree-indent-@Indent @(IsSelected ? "selected" : "") @FileNode.GetIconClass(Node.Name)"
         @onclick="SelectFile"
         @onclick:stopPropagation="true">
        <span class="tree-icon file-icon">
            @switch (Node.FileType)
            {
                case "markdown":
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14,2 14,8 20,8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10,9 9,9 8,9"/>
                    </svg>
                    break;
                case "excel":
                    @if (Node.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                            <polyline points="14,2 14,8 20,8"/>
                            <line x1="8" y1="13" x2="16" y2="13"/>
                            <line x1="8" y1="17" x2="16" y2="17"/>
                            <line x1="8" y1="9" x2="16" y2="9"/>
                        </svg>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                            <polyline points="14,2 14,8 20,8"/>
                            <rect x="8" y="12" width="8" height="6" rx="1"/>
                        </svg>
                    }
                    break;
                case "pdf":
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14,2 14,8 20,8"/>
                    </svg>
                    break;
                default:
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14,2 14,8 20,8"/>
                    </svg>
                    break;
            }
        </span>
        <span class="tree-name">@Node.Name</span>
    </div>
}

@code {
    [Parameter] public FileNode Node { get; set; } = new();
    [Parameter] public int Indent { get; set; }
    [Parameter] public string? SelectedFilePath { get; set; }
    [Parameter] public EventCallback<FileNode> OnFileSelected { get; set; }

    private bool _isExpanded = true;

    private bool IsSelected => Node.Type == "file" && Node.Path == SelectedFilePath;

    private void ToggleExpanded()
    {
        _isExpanded = !_isExpanded;
    }

    private async Task SelectFile()
    {
        await OnFileSelected.InvokeAsync(Node);
    }
}
